# ──────────────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5) — Microsoft Entra ID (single-tenant)
# ──────────────────────────────────────────────────────────────────────────
#
# Register an app in the Azure Portal → Microsoft Entra ID → App registrations:
#   1.  Note the "Application (client) ID"  → AUTH_MICROSOFT_ENTRA_ID_ID
#   2.  Create a client secret               → AUTH_MICROSOFT_ENTRA_ID_SECRET
#   3.  Note the "Directory (tenant) ID" and build the issuer URL below.
#   4.  Add a redirect URI:  http://localhost:3000/api/auth/callback/microsoft-entra-id
#
# Auth.js infers these env vars automatically (no code changes needed).

# Application (client) ID from the Entra ID app registration.
AUTH_MICROSOFT_ENTRA_ID_ID=

# Client secret value (not the secret ID).
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Single-tenant issuer — restricts sign-in to your organisation only.
# Replace <tenant-id> with your Directory (tenant) ID.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0/

# ──────────────────────────────────────────────────────────────────────────
# Auth.js core settings
# ──────────────────────────────────────────────────────────────────────────

# Secret used to sign/encrypt the session JWT cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL (no trailing slash).
# Local dev:  http://localhost:3000
# Production: https://your-app.azurewebsites.net
AUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Azure Table Storage (existing — not auth-related, shown for completeness)
# ──────────────────────────────────────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=
